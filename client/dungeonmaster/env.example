# Copy to .env.local or .env (Vue CLI loads these for the dev server).

DM_FRONTEND_PORT=8080
# Same Web client ID as DM_GOOGLE_CLIENT_ID on the server (OAuth client type: Web application).
# Google Cloud → Authorized JavaScript origins must include every URL you use (e.g. https://your.fqdn).
VUE_APP_DM_GOOGLE_CLIENT_ID=

# Production behind NPM same-host /api: leave unset (axios uses relative /api).
# Split API host only: VUE_APP_DM_API_BASE=https://api.example.com
# DM_API_BASE=http://localhost:5001

# Where `npm run serve` proxies /api (default http://127.0.0.1:5001)
# DM_API_PROXY_TARGET=http://127.0.0.1:5001

# Local http://localhost:8080: leave DM_DEV_WEBSOCKET_URL unset — vue.config omits client.webSocketURL so
# webpack-dev-server uses one live-reload WebSocket from the page URL (avoids many failing /ws connections in DevTools).
# HTTPS in browser but dev server is HTTP (NPM → :8080): set one of the following or the client uses ws://<LAN>:8080 (blocked).
# NPM must enable WebSockets and proxy path /ws to the dev server.
# DM_DEV_WEBSOCKET_URL=wss://dnd.example.com/ws  (no :8080 in the URL — vue.config forces browser WSS to port 443)
# Or rely on your public site URL (https only → wss + /ws on hostname, port 443 in the dev client):
# DM_PUBLIC_URL=https://dnd.example.com
# Non-standard public HTTPS port (rare):
# DM_WSS_PUBLIC_PORT=8443
