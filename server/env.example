# Copy to .env and fill in values. Never commit real secrets.

DM_MONGODB_URI=mongodb://localhost:27017/dungeonmaster
DM_OPENAI_API_KEY=

# Google Sign-In (Web client ID from Google Cloud Console — same value as VUE_APP_DM_GOOGLE_CLIENT_ID).
# In Console, Authorized JavaScript origins must match the UI URL exactly (e.g. http://localhost:8080).
DM_GOOGLE_CLIENT_ID=

# JWT signing secret: use a long random string (e.g. openssl rand -hex 32).
# Do NOT use your Google OAuth client secret here.
DM_JWT_SECRET=

# Browser origin(s) for CORS. For a public FQDN, set this to the exact URL users open (scheme + host, no trailing slash).
DM_FRONTEND_URL=http://localhost:8080
# Optional: same as DM_FRONTEND_URL when using a reverse proxy + HTTPS FQDN (also added to CORS allow list).
# DM_PUBLIC_URL=https://dungeon.example.com
# (Vue dev client: set DM_DEV_WEBSOCKET_URL or DM_PUBLIC_URL in client/dungeonmaster/.env — WSS uses explicit port 443; see client env.example.)
# Trust X-Forwarded-* from reverse proxy (nginx, Caddy, Traefik). Required for correct req.ip / req.protocol behind TLS termination.
# DM_TRUST_PROXY=1

# Reverse proxy — Nginx Proxy Manager (NPM)
# -----------------------------------------------------------------------------
# On the Node host set: DM_TRUST_PROXY=1 so Express trusts X-Forwarded-*.
#
# NPM UI: Hosts → Proxy Hosts → Add (or Edit) the host that serves your app (e.g. dnd.example.com).
#   • Domain Names: public FQDN
#   • Scheme: HTTP — Forward Hostname / IP: where Node runs (127.0.0.1, LAN IP, or host.docker.internal from NPM container)
#   • Forward Port: Node listen port (e.g. 5001)
#   • SSL certificate: enable as usual
#   • Websockets Support: optional for this app (SSE does not require it); enable if you add WebSockets later
#
# Same Proxy Host → Advanced tab → “Custom Nginx Configuration”. Paste the block below UNCOMMENTED in NPM
# (remove the leading # from each nginx line only — keep this .env file as comments if you copy from here).
# Replace YOUR_FORWARD_HOST and YOUR_FORWARD_PORT with the same Forward Hostname and Forward Port as above.
#
# --- paste into NPM (after removing # from each line) ---
# proxy_connect_timeout 600s;
# proxy_send_timeout 600s;
# proxy_read_timeout 600s;
# send_timeout 600s;
#
# location ^~ /api/game-state/events/ {
#     proxy_set_header Host $host;
#     proxy_set_header X-Real-IP $remote_addr;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_set_header X-Forwarded-Proto $scheme;
#     proxy_set_header X-Forwarded-Host $host;
#     proxy_pass http://YOUR_FORWARD_HOST:YOUR_FORWARD_PORT;
#     proxy_http_version 1.1;
#     proxy_set_header Connection "";
#     proxy_buffering off;
#     proxy_cache off;
#     proxy_read_timeout 86400s;
#     send_timeout 86400s;
# }
# --- end paste ---
#
# If NPM rejects the config, check the proxy host error log. Avoid duplicating a full `location /` here.
#
# Optional: per-stage LLM ceiling (default 60000 ms for non-creative stages). Does not fix a proxy that closes earlier.
# DM_STAGE_TIMEOUT_MS=120000
# Creative-seed stage only (Promise.race around the small JSON draw). Default 120000 ms if unset; falls back to DM_STAGE_TIMEOUT_MS when set. Use when slow/reasoning models hit stage_timeout before returning.
# DM_CREATIVE_SEED_TIMEOUT_MS=180000
# Lobby start-party-adventure: each of factions / majorNPCs / keyLocations / openingFrame uses this per-stage race (sequential). Default 120000 ms if unset. Raise if POST /api/game-session/start-party-adventure returns 500 with CAMPAIGN_STAGE_*.
# DM_LOBBY_STAGE_TIMEOUT_MS=180000
# Node socket timeout for long LLM routes: generate-campaign-core, generate-character (default 900000 ms). Raise proxy_read_timeout too or you still get 504 from nginx/openresty.
# DM_LONG_REQUEST_SOCKET_MS=900000
# Extra CORS origins (comma-separated), e.g. alternate FQDNs or staging URLs.
# DM_CORS_ORIGINS=https://www.example.com,https://staging.example.com
# Bind address (default: all interfaces). Use 127.0.0.1 to listen on localhost only.
# DM_BIND_HOST=0.0.0.0

# Draft / lobby parties (new table from create-party, or character generated without a substantive campaign): MongoDB TTL deletes the GameState after this many minutes (single-member games only). Set to 0 to disable. Default 10080 (= 7 days).
# DM_DRAFT_PARTY_TTL_MINUTES=10080

# PC names on /generate-character: Iron Arachne MUNA (https://names.ironarachne.com/). Given + family by ancestry. When race is not "random", the server picks the name before the LLM call and injects it into the prompt so JSON + backstory match. The client may call POST /api/game-session/preview-character-name first to show that name in the form while generation runs. Set false/0 to keep model-only names. Optional base URL override.
# DM_USE_IRON_ARACHNE_NAMES=true
# DM_IRON_ARACHNE_NAMES_URL=https://names.ironarachne.com

# Optional
# DM_OPENAI_MODEL=gpt-3.5-turbo
